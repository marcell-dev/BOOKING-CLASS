# SECRET_KEY: Required for external service calls.
# The hosting provider automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the UI.
SECRET_KEY="MY_SECRET_KEY"

# APP_URL: The URL where this applet is hosted.
# The hosting provider automatically injects this at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and endpoints.
APP_URL="MY_APP_URL"